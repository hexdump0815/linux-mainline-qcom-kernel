--- a/arch/arm64/boot/dts/qcom/msm8916-asus-z010d.dts
+++ b/arch/arm64/boot/dts/qcom/msm8916-asus-z010d.dts
@@ -159,6 +159,43 @@ &blsp_uart2 {
 	status = "okay";
 };
 
+&gpu {
+	status = "okay";
