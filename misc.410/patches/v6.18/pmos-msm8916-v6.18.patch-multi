 		function = "gpio";
@@ -486,6 +503,7 @@ mdss_sleep: mdss-sleep-state {
 		bias-pull-down;
 	};
 
+
 	muic_i2c_default: muic-i2c-default-state {
 		pins = "gpio105", "gpio106";
 		function = "gpio";
-- 
