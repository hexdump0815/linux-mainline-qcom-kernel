+++ b/arch/arm64/boot/dts/qcom/msm8916-lg-c50.dts
@@ -65,6 +65,36 @@ &blsp_uart2 {
 	status = "okay";
 };
 
+&gpu {
+	status = "okay";
+};
+
+&mdss {
+	status = "okay";
+};
+
+&mdss_dsi0 {
+	panel@0 {
+		compatible = "lg,c50-panel";
