From a430785763572421b223cea708f61dfc23f62d3c Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?Ga=C3=ABtan=20Andr=C3=A9?= <rvlander@gaetanandre.eu>
Date: Sun, 8 Mar 2020 09:46:41 +0100
Subject: [PATCH 131/163] FIXME: arm64: dts: qcom:
 apq8016-samsung-matissevewifi: add display panel (v4)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Signed-off-by: Gaëtan André <rvlander@gaetanandre.eu>

v2: Make reset-gpios GPIO_ACTIVE_LOW
v3: Add &mdss { status = "okay"; };
v4: - Set up fixed regulators properly
    - Allow turning off LCD regulator
    - Set up clk-pwm for brightness control
    - Use panel-simple instead

Signed-off-by: Stephan Gerhold <stephan@gerhold.net>
---
 .../qcom/apq8016-samsung-matissevewifi.dts    | 107 ++++++++++++++++++
 1 file changed, 107 insertions(+)

diff --git a/arch/arm64/boot/dts/qcom/apq8016-samsung-matissevewifi.dts b/arch/arm64/boot/dts/qcom/apq8016-samsung-matissevewifi.dts
index f2b3a38b26d8..be7631a969f4 100644
--- a/arch/arm64/boot/dts/qcom/apq8016-samsung-matissevewifi.dts
+++ b/arch/arm64/boot/dts/qcom/apq8016-samsung-matissevewifi.dts
@@ -77,6 +77,69 @@ home-button {
 		};
 	};
 
+	reg_lcd: regulator-lcd {
+		compatible = "regulator-fixed";
+		regulator-name = "lcd";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-boot-on;
+
+		gpio = <&tlmm 8 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+		startup-delay-us = <500>;
+
+		pinctrl-0 = <&lcd_en_default>;
+		pinctrl-names = "default";
+	};
+
+	reg_lvds_1p2: regulator-lvds-1p2 {
+		compatible = "regulator-fixed";
+		regulator-name = "lvds_1p2";
+		regulator-min-microvolt = <1200000>;
+		regulator-max-microvolt = <1200000>;
+
+		/* FIXME: Set up TC358764 DSI->LVDS bridge properly */
+		regulator-always-on;
+		regulator-boot-on;
+
+		gpio = <&tlmm 17 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+		startup-delay-us = <200>;
+
+		pinctrl-0 = <&lvds_en_default>;
+		pinctrl-names = "default";
+	};
+
+	reg_lvds_1p8: regulator-lvds-1p8 {
+		compatible = "regulator-fixed";
+		regulator-name = "lvds_1p8";
+		regulator-min-microvolt = <1800000>;
+		regulator-max-microvolt = <1800000>;
+
+		/* FIXME: Set up TC358764 DSI->LVDS bridge properly */
+		regulator-always-on;
+		regulator-boot-on;
+		startup-delay-us = <200>;
+
+		gpio = <&tlmm 17 GPIO_ACTIVE_HIGH>;
+		enable-active-high;
+	};
+
+	reg_lvds_3p3: regulator-lvds-3p3 {
+		compatible = "regulator-fixed";
+		regulator-name = "lvds_3p3";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+
+		/* FIXME: Set up TC358764 DSI->LVDS bridge properly */
+		regulator-always-on;
