From 99b6fa734fbebb57cabf743427927117e196b67d Mon Sep 17 00:00:00 2001
From: Gareth Peoples <mail@gpeopl.es>
Date: Wed, 30 Mar 2022 19:07:41 +0100
Subject: [PATCH 072/163] drm/panel: samsung-s6288a0: Add
 dci_dcs_write_seq(dsi, 0xf7, 0x03);

The display shows distorted colours otherwise.

Signed-off-by: Gareth Peoples <mail@gpeopl.es>
---
 drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6288a0.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6288a0.c b/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6288a0.c
index 88721a293bb8..ceee41c6b86e 100644
--- a/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6288a0.c
+++ b/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6288a0.c
@@ -65,6 +65,7 @@ static int samsung_on(struct samsung *ctx)
 				     0x40, 0x08, 0x20, 0x00, 0x08);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb6, 0x28, 0x0b);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, MIPI_DCS_WRITE_POWER_SAVE, 0x00);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xf7, 0x03);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xfc, 0xa5, 0xa5);
 	mipi_dsi_dcs_set_display_on_multi(&dsi_ctx);
 
-- 
2.47.3


From 35759b5b8170a11ee2a12103f2f7099c1275d737 Mon Sep 17 00:00:00 2001
From: Stephan Gerhold <stephan@gerhold.net>
Date: Thu, 10 Nov 2022 19:13:37 +0100
Subject: [PATCH 073/163] drm/panel: longcheer-truly-nt35695: Force DSI video
 mode

Command mode is somewhat broken in the mainline kernel.
Change some magic bits to force video mode for now.

Signed-off-by: Stephan Gerhold <stephan@gerhold.net>
---
 .../panel/msm8916-generated/panel-longcheer-truly-nt35695.c   | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c b/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c
index be4605109eda..8d018082e535 100644
--- a/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c
+++ b/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c
@@ -564,7 +564,7 @@ static int truly_nt35695_on(struct truly_nt35695 *ctx)
 	mipi_dsi_usleep_range(&dsi_ctx, 1000, 2000);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x3b,
 				     0x03, 0x08, 0x02, 0x04, 0x04);
-	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xbb, 0x10);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xbb, 0x03); /* 0x10 -> 0x03 for video mode */
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xfb, 0x01);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x51, 0xff);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0x53, 0x2c);
@@ -690,7 +690,7 @@ static int truly_nt35695_probe(struct mipi_dsi_device *dsi)
 
 	dsi->lanes = 4;
 	dsi->format = MIPI_DSI_FMT_RGB888;
-	dsi->mode_flags = MIPI_DSI_MODE_VIDEO_SYNC_PULSE |
+	dsi->mode_flags = MIPI_DSI_MODE_VIDEO | MIPI_DSI_MODE_VIDEO_SYNC_PULSE |
 			  MIPI_DSI_MODE_NO_EOT_PACKET |
 			  MIPI_DSI_CLOCK_NON_CONTINUOUS | MIPI_DSI_MODE_LPM;
 
-- 
2.47.3


From cdcd92b4fd6248887b525024e144b61243e58a0c Mon Sep 17 00:00:00 2001
From: Stephan Gerhold <stephan@gerhold.net>
Date: Thu, 10 Nov 2022 19:16:12 +0100
Subject: [PATCH 074/163] drm/panel: longcheer-truly-nt35695: Fix missing pixel
 line

For some reason the current panel timing causes the first pixel line to
be missing. Changing the timing slightly seems to fix it for some
reason.

Signed-off-by: Stephan Gerhold <stephan@gerhold.net>
---
 .../panel/msm8916-generated/panel-longcheer-truly-nt35695.c | 6 +++---
 1 file changed, 3 insertions(+), 3 deletions(-)

diff --git a/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c b/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c
index 8d018082e535..d412446f8411 100644
--- a/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c
+++ b/drivers/gpu/drm/panel/msm8916-generated/panel-longcheer-truly-nt35695.c
@@ -637,15 +637,15 @@ static int truly_nt35695_unprepare(struct drm_panel *panel)
 }
 
 static const struct drm_display_mode truly_nt35695_mode = {
-	.clock = (1080 + 120 + 20 + 90) * (1920 + 20 + 2 + 8) * 60 / 1000,
+	.clock = (1080 + 120 + 20 + 90) * (1920 + 20 + 1 + 8) * 60 / 1000,
 	.hdisplay = 1080,
 	.hsync_start = 1080 + 120,
 	.hsync_end = 1080 + 120 + 20,
 	.htotal = 1080 + 120 + 20 + 90,
 	.vdisplay = 1920,
 	.vsync_start = 1920 + 20,
-	.vsync_end = 1920 + 20 + 2,
-	.vtotal = 1920 + 20 + 2 + 8,
+	.vsync_end = 1920 + 20 + 1,
+	.vtotal = 1920 + 20 + 1 + 8,
 	.width_mm = 62,
 	.height_mm = 110,
 	.type = DRM_MODE_TYPE_DRIVER,
-- 
2.47.3


From 60d4a4d03fa4eca46a50cb7aec9f29d46ff99ab3 Mon Sep 17 00:00:00 2001
From: "Lin, Meng-Bo" <linmengbo0689@protonmail.com>
Date: Mon, 14 Nov 2022 17:08:17 +0000
Subject: [PATCH 075/163] drm/panel: s6e3fa2-ams549eh01: Add missing
 mipi_dsi_dcs_set_display_on()

Without mipi_dsi_dcs_set_display_on(), s6e3fa2-ams549eh01 won't be
enabled on A7.

Signed-off-by: Lin, Meng-Bo <linmengbo0689@protonmail.com>
---
 .../panel/msm8916-generated/panel-samsung-s6e3fa2-ams549eh01.c   | 1 +
 1 file changed, 1 insertion(+)

diff --git a/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6e3fa2-ams549eh01.c b/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6e3fa2-ams549eh01.c
index 4aa553f199fd..f30708470c4f 100644
--- a/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6e3fa2-ams549eh01.c
+++ b/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6e3fa2-ams549eh01.c
@@ -85,6 +85,7 @@ static int s6e3fa2_ams549eh01_on(struct s6e3fa2_ams549eh01 *ctx)
 	mipi_dsi_generic_write_seq_multi(&dsi_ctx, 0xfc, 0xa5, 0xa5);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, MIPI_DCS_WRITE_MEMORY_START);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, MIPI_DCS_WRITE_MEMORY_CONTINUE);
+	mipi_dsi_dcs_set_display_on_multi(&dsi_ctx);
 
 	return dsi_ctx.accum_err;
 }
-- 
2.47.3


