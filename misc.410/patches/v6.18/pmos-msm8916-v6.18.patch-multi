index 20ae784cfeab..138050a44518 100644
--- a/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6e8aa5x01-ams520kt01.c
+++ b/drivers/gpu/drm/panel/msm8916-generated/panel-samsung-s6e8aa5x01-ams520kt01.c
@@ -67,6 +67,7 @@ static int s6e8aa5x01_ams520kt01_on(struct s6e8aa5x01_ams520kt01 *ctx)
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb8, 0xa8);
 	mipi_dsi_msleep(&dsi_ctx, 120);
 	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xf0, 0xa5, 0xa5);
+	mipi_dsi_dcs_set_display_on_multi(&dsi_ctx);
 
 	return dsi_ctx.accum_err;
 }
-- 
