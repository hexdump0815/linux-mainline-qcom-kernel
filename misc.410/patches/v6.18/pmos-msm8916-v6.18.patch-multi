+				     0x18, 0x18, 0x18, 0x18, 0x18, 0x18, 0x18,
+				     0x18, 0x18);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xcc, 0x01);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xb6, 0x4c, 0x4c);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xe0,
+				     0x00, 0x10, 0x16, 0x2d, 0x33, 0x3f, 0x23,
+				     0x3e, 0x07, 0x0b, 0x0d, 0x17, 0x0e, 0x12,
+				     0x14, 0x12, 0x13, 0x06, 0x11, 0x13, 0x18,
+				     0x00, 0x0f, 0x16, 0x2e, 0x33, 0x3f, 0x23,
+				     0x3d, 0x07, 0x0b, 0x0d, 0x18, 0x0f, 0x12,
+				     0x14, 0x12, 0x14, 0x07, 0x11, 0x12, 0x17);
+	mipi_dsi_dcs_write_seq_multi(&dsi_ctx, 0xc0, 0x30, 0x14);
